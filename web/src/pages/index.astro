---
import '../styles/global.css';
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>STS2 Run History</title>
  </head>
  <body class="bg-base-200 min-h-screen">
    <div class="container mx-auto max-w-4xl px-4 py-8">
      <h1 class="text-3xl font-bold mb-6">STS2 Run History</h1>

      <!-- ── Upload ── -->
      <div class="card bg-base-100 shadow mb-6">
        <div class="card-body">
          <h2 class="card-title">Upload run</h2>
          <div>
            <button class="btn btn-primary" id="open-dialog">Choose file…</button>
            <p id="status" class="mt-3 text-sm"></p>
          </div>
        </div>
      </div>

      <!-- ── Upload modal ── -->
      <dialog id="upload-dialog" class="modal">
        <div class="modal-box">
          <h3 class="font-bold text-lg">Upload .run files</h3>
          <p id="path-hint" class="text-sm text-base-content/60 mt-1 mb-2 hidden"></p>
          <input type="file" id="run-file" accept=".run" multiple class="file-input file-input-bordered w-full my-3" />
          <div class="modal-action">
            <button type="button" id="cancel-upload" class="btn btn-ghost">Cancel</button>
            <button type="button" id="confirm-upload" class="btn btn-primary">Upload</button>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>

      <!-- ── Browse ── -->
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="card-title">Browse runs</h2>
          <form id="query-form" class="flex flex-wrap gap-4 items-end">
            <div class="form-control flex-1 min-w-48">
              <label class="label"><span class="label-text">Cards</span></label>
              <select id="cards-select" multiple class="select select-bordered h-32"></select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">Mode</span></label>
              <select id="mode-select" class="select select-bordered">
                <option value="single">Single player</option>
                <option value="multi">Multiplayer</option>
                <option value="both">Both</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
          </form>

          <div id="results" class="mt-4"></div>
        </div>
      </div>
    </div>

    <script>
      // ── Upload dialog ──────────────────────────────────────────
      const dialog = document.getElementById('upload-dialog');

      document.getElementById('open-dialog').addEventListener('click', () => {
        document.getElementById('status').textContent = '';
        const hint = document.getElementById('path-hint');
        if (navigator.userAgent.includes('Windows')) {
          hint.textContent = 'Default location: %AppData%\\SlayTheSpire2\\steam';
          hint.classList.remove('hidden');
        }
        dialog.showModal();
      });

      document.getElementById('cancel-upload').addEventListener('click', () => dialog.close());

      document.getElementById('confirm-upload').addEventListener('click', async () => {
        const files = Array.from(document.getElementById('run-file').files);
        const status = document.getElementById('status');
        if (files.length === 0) return;

        try {
          const runs = await Promise.all(files.map(f => f.text().then(JSON.parse)));
          const resp = await fetch('/api/v1/runs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(runs),
          });
          if (resp.ok) {
            const { ids } = await resp.json();
            status.className = 'mt-3 text-sm text-success';
            status.textContent = `Uploaded ${ids.length} run${ids.length === 1 ? '' : 's'} — ID${ids.length === 1 ? '' : 's'} ${ids.join(', ')}`;
            dialog.close();
          } else {
            const text = await resp.text();
            status.className = 'mt-3 text-sm text-error';
            status.textContent = `Upload failed (${resp.status}): ${text}`;
            dialog.close();
          }
        } catch (err) {
          status.className = 'mt-3 text-sm text-error';
          status.textContent = `Upload failed: ${err.message}`;
          dialog.close();
        }
      });

      // ── Cards select ──────────────────────────────────────────
      async function populateCards() {
        const select = document.getElementById('cards-select');
        try {
          const cards = await (await fetch('/api/v1/cards')).json();
          select.innerHTML = cards.map(c => `<option value="${c}">${c}</option>`).join('');
        } catch {
          // leave empty — search still works with no selection
        }
      }
      populateCards();

      // also refresh after a successful upload so new cards appear
      document.getElementById('confirm-upload').addEventListener('click', () => {
        setTimeout(populateCards, 500);
      }, { capture: true });

      // ── Query form ─────────────────────────────────────────────
      let currentOffset = 0;
      const PAGE_SIZE = 20;

      async function fetchRuns(offset = 0) {
        const cards = Array.from(document.getElementById('cards-select').selectedOptions).map(o => o.value);
        const mode = document.getElementById('mode-select').value;

        const params = new URLSearchParams({ limit: PAGE_SIZE, offset, mode });
        cards.forEach(c => params.append('cards', c));

        const resp = await fetch(`/api/v1/runs?${params}`);
        if (!resp.ok) throw new Error(`${resp.status} ${resp.statusText}`);
        return resp.json();
      }

      function renderResults(data, offset) {
        const container = document.getElementById('results');
        if (data.items.length === 0) {
          container.innerHTML = '<p class="text-base-content/60">No runs found.</p>';
          return;
        }

        const pct = data.total > 0 ? Math.round(data.wins / data.total * 100) : 0;
        const statsHtml = `<p class="text-sm mb-3">${data.wins} / ${data.total} wins (${pct}%)</p>`;

        const rows = data.items.map(r => `
          <tr>
            <td>${r.id}</td>
            <td>${r.ascension}</td>
            <td class="${r.win ? 'text-success font-medium' : 'text-error font-medium'}">${r.win ? 'Win' : 'Loss'}</td>
            <td>${r.build_id}</td>
          </tr>
        `).join('');

        container.innerHTML = statsHtml + `
          <div class="overflow-x-auto">
            <table class="table table-zebra">
              <thead><tr><th>ID</th><th>Ascension</th><th>Result</th><th>Build</th></tr></thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
          <div class="flex gap-2 items-center mt-3 text-sm">
            <button id="prev-btn" class="btn btn-sm btn-ghost" ${offset === 0 ? 'disabled' : ''}>← Prev</button>
            <span class="text-base-content/60">Showing ${offset + 1}–${offset + data.items.length}</span>
            <button id="next-btn" class="btn btn-sm btn-ghost" ${data.items.length < PAGE_SIZE ? 'disabled' : ''}>Next →</button>
          </div>
        `;

        document.getElementById('prev-btn').addEventListener('click', () => loadPage(offset - PAGE_SIZE));
        document.getElementById('next-btn').addEventListener('click', () => loadPage(offset + PAGE_SIZE));
      }

      async function loadPage(offset) {
        currentOffset = offset;
        try {
          const data = await fetchRuns(offset);
          renderResults(data, offset);
        } catch (err) {
          document.getElementById('results').innerHTML = `<p class="text-error text-sm">Error: ${err.message}</p>`;
        }
      }

      document.getElementById('query-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        loadPage(0);
      });
    </script>
  </body>
</html>
