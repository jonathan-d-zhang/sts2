---
import '../styles/global.css';
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>STS2 Run History</title>
  </head>
  <body class="bg-base-200 min-h-screen">
    <div class="container mx-auto max-w-4xl px-4 py-8">
      <h1 class="text-3xl font-bold mb-6">STS2 Run History</h1>

      <!-- ── Upload ── -->
      <div class="card bg-base-100 shadow mb-6">
        <div class="card-body">
          <h2 class="card-title">Upload run</h2>
          <div>
            <button class="btn btn-primary" id="open-dialog">Choose file…</button>
            <p id="status" class="mt-3 text-sm"></p>
          </div>
        </div>
      </div>

      <!-- ── Upload modal ── -->
      <dialog id="upload-dialog" class="modal">
        <div class="modal-box">
          <h3 class="font-bold text-lg">Upload .run files</h3>
          <p id="upload-error" class="text-error text-sm mt-1 hidden"></p>
          <div id="drop-zone" class="border-2 border-dashed border-base-300 rounded-lg p-6 text-center cursor-pointer hover:border-primary transition-colors my-3">
            <p id="drop-label" class="text-base-content/60 text-sm">Drag &amp; drop .run files here, or <span class="text-primary underline">click to browse</span></p>
            <input type="file" id="run-file" accept=".run" multiple class="hidden" />
          </div>
          <div class="modal-action">
            <button type="button" id="cancel-upload" class="btn btn-ghost">Cancel</button>
            <button type="button" id="confirm-upload" class="btn btn-primary">Upload</button>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>

      <!-- ── Browse ── -->
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="card-title">Browse runs</h2>
          <form id="query-form" class="flex flex-wrap gap-4 items-end">
            <div class="form-control flex-1 min-w-48">
              <label class="label"><span class="label-text">Cards</span></label>
              <input type="text" id="cards-search" placeholder="Filter cards…" class="input input-bordered input-sm w-full mb-1" />
              <select id="cards-select" multiple class="select select-bordered h-32"></select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">Mode</span></label>
              <select id="mode-select" class="select select-bordered">
                <option value="single">Single player</option>
                <option value="multi">Multiplayer</option>
                <option value="both">Both</option>
              </select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">Ascension</span></label>
              <select id="ascension-select" class="select select-bordered">
                <option value="">All</option>
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
                <option value="9">9</option>
                <option value="10">10</option>
              </select>
            </div>
            <button type="submit" id="search-btn" class="btn btn-primary">Search</button>
            <button type="button" id="clear-btn" class="btn btn-ghost">Clear</button>
          </form>

          <div id="results" class="mt-4"></div>
        </div>
      </div>
    </div>

    <script>
      function esc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      // ── Upload dialog ──────────────────────────────────────────
      const dialog = document.getElementById('upload-dialog');
      const dropZone = document.getElementById('drop-zone');
      const fileInput = document.getElementById('run-file');
      const dropLabel = document.getElementById('drop-label');
      let selectedFiles = [];

      function updateDropLabel() {
        dropLabel.textContent = selectedFiles.length > 0
          ? `${selectedFiles.length} file${selectedFiles.length === 1 ? '' : 's'} selected`
          : '';
        if (selectedFiles.length === 0) {
          dropLabel.innerHTML = 'Drag &amp; drop .run files here, or <span class="text-primary underline">click to browse</span>';
        }
      }

      dropZone.addEventListener('click', () => fileInput.click());
      fileInput.addEventListener('change', () => {
        selectedFiles = Array.from(fileInput.files);
        updateDropLabel();
      });
      dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('border-primary', 'bg-base-200');
      });
      dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('border-primary', 'bg-base-200');
      });
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-primary', 'bg-base-200');
        selectedFiles = Array.from(e.dataTransfer.files).filter(f => f.name.endsWith('.run'));
        updateDropLabel();
      });

      document.getElementById('open-dialog').addEventListener('click', () => {
        document.getElementById('status').textContent = '';
        const uploadError = document.getElementById('upload-error');
        uploadError.textContent = '';
        uploadError.classList.add('hidden');
        selectedFiles = [];
        updateDropLabel();
        dialog.showModal();
      });

      document.getElementById('cancel-upload').addEventListener('click', () => dialog.close());

      document.getElementById('confirm-upload').addEventListener('click', async () => {
        const files = selectedFiles;
        const status = document.getElementById('status');
        const uploadError = document.getElementById('upload-error');
        if (files.length === 0) return;

        uploadError.textContent = '';
        uploadError.classList.add('hidden');

        try {
          const runs = await Promise.all(files.map(f => f.text().then(JSON.parse)));
          const resp = await fetch('/api/v1/runs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(runs),
          });
          if (resp.ok) {
            const { ids } = await resp.json();
            status.className = 'mt-3 text-sm text-success';
            status.textContent = `Uploaded ${ids.length} run${ids.length === 1 ? '' : 's'} — ID${ids.length === 1 ? '' : 's'} ${ids.join(', ')}`;
            dialog.close();
          } else {
            const text = await resp.text();
            uploadError.textContent = `Upload failed (${resp.status}): ${text}`;
            uploadError.classList.remove('hidden');
          }
        } catch (err) {
          uploadError.textContent = `Upload failed: ${err.message}`;
          uploadError.classList.remove('hidden');
        }
      });

      // ── Cards select ──────────────────────────────────────────
      async function populateCards() {
        const select = document.getElementById('cards-select');
        select.innerHTML = '<option disabled>Loading…</option>';
        try {
          const cards = await (await fetch('/api/v1/cards')).json();
          select.innerHTML = cards.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join('');
        } catch {
          select.innerHTML = '';
        }
      }
      const { cards: initialCards, offset: initialOffset } = restoreFilters();
      populateCards().then(() => {
        if (initialCards.length > 0) {
          Array.from(document.getElementById('cards-select').options).forEach(o => {
            o.selected = initialCards.includes(o.value);
          });
        }
        loadPage(initialOffset);
      });

      async function populateAscensionCounts() {
        try {
          const data = await fetch('/api/v1/ascensions').then(r => r.json());
          const countMap = Object.fromEntries(data.map(d => [String(d.ascension), d.count]));
          Array.from(document.getElementById('ascension-select').options).forEach(o => {
            if (o.value !== '') {
              const count = countMap[o.value];
              o.textContent = count !== undefined ? `${o.value} (${count})` : o.value;
            }
          });
        } catch {
          // leave options as-is
        }
      }
      populateAscensionCounts();

      document.getElementById('cards-search').addEventListener('input', (e) => {
        const q = e.target.value.toLowerCase();
        Array.from(document.getElementById('cards-select').options).forEach(o => {
          o.hidden = !o.value.toLowerCase().includes(q);
        });
      });

      // also refresh after a successful upload so new cards appear
      document.getElementById('confirm-upload').addEventListener('click', () => {
        setTimeout(populateCards, 500);
      }, { capture: true });

      // ── Query form ─────────────────────────────────────────────
      const PAGE_SIZE = 20;

      async function fetchRuns(offset = 0) {
        const cards = Array.from(document.getElementById('cards-select').selectedOptions).map(o => o.value);
        const mode = document.getElementById('mode-select').value;
        const ascension = document.getElementById('ascension-select').value;

        const filterParams = new URLSearchParams({ mode });
        cards.forEach(c => filterParams.append('cards', c));
        if (ascension !== '') filterParams.append('ascension', ascension);
        if (offset > 0) filterParams.set('offset', offset);
        history.replaceState({}, '', `?${filterParams}`);

        const params = new URLSearchParams(filterParams);
        params.set('limit', PAGE_SIZE);
        params.set('offset', offset);

        const resp = await fetch(`/api/v1/runs?${params}`);
        if (!resp.ok) throw new Error(`${resp.status} ${resp.statusText}`);
        return resp.json();
      }

      function restoreFilters() {
        const p = new URLSearchParams(window.location.search);
        const mode = p.get('mode');
        if (mode) document.getElementById('mode-select').value = mode;
        const ascension = p.get('ascension');
        if (ascension !== null) document.getElementById('ascension-select').value = ascension;
        return { cards: p.getAll('cards'), offset: parseInt(p.get('offset') ?? '0', 10) };
      }

      function renderResults(data, offset) {
        const container = document.getElementById('results');
        if (data.items.length === 0) {
          container.innerHTML = '<p class="text-base-content/60">No runs found.</p>';
          return;
        }

        const pct = data.total > 0 ? Math.round(data.wins / data.total * 100) : 0;
        const statsHtml = `<p class="text-sm mb-3">${data.wins} / ${data.total} wins (${pct}%)</p>`;

        const rows = data.items.map(r => `
          <tr class="cursor-pointer" data-run-id="${r.id}">
            <td>${r.id}</td>
            <td>${r.ascension}</td>
            <td><span class="badge ${r.win ? 'badge-success' : 'badge-error'}">${r.win ? 'Win' : 'Loss'}</span></td>
            <td>${esc(r.build_id)}</td>
          </tr>
        `).join('');

        container.innerHTML = statsHtml + `
          <div class="overflow-x-auto">
            <table class="table table-zebra">
              <thead><tr><th>ID</th><th>Ascension</th><th>Result</th><th>Build</th></tr></thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
          <div class="flex gap-2 items-center mt-3 text-sm">
            <button id="prev-btn" class="btn btn-sm btn-ghost" ${offset === 0 ? 'disabled' : ''}>← Prev</button>
            <span class="text-base-content/60">Showing ${offset + 1}–${offset + data.items.length} of ${data.total}</span>
            <button id="next-btn" class="btn btn-sm btn-ghost" ${data.items.length < PAGE_SIZE ? 'disabled' : ''}>Next →</button>
          </div>
        `;

        document.getElementById('prev-btn').addEventListener('click', () => loadPage(offset - PAGE_SIZE));
        document.getElementById('next-btn').addEventListener('click', () => loadPage(offset + PAGE_SIZE));

        document.querySelectorAll('tbody tr[data-run-id]').forEach(row => {
          row.addEventListener('click', async () => {
            const runId = row.dataset.runId;
            const existing = document.getElementById(`detail-${runId}`);
            if (existing) { existing.remove(); return; }
            document.querySelectorAll('tr.detail-row').forEach(r => r.remove());
            const detailRow = document.createElement('tr');
            detailRow.id = `detail-${runId}`;
            detailRow.className = 'detail-row';
            detailRow.innerHTML = '<td colspan="4" class="py-2"><span class="loading loading-spinner loading-xs"></span></td>';
            row.after(detailRow);
            try {
              const run = await fetch(`/api/v1/runs/${runId}`).then(r => r.json());
              const players = run.players.map(p => `
                <div class="mb-2">
                  <span class="font-medium">${esc(p.character)}</span>
                  <div class="text-xs text-base-content/60 mt-1">${p.deck.map(c => esc(c.id)).join(', ')}</div>
                </div>`).join('');
              detailRow.innerHTML = `<td colspan="4" class="bg-base-200 text-sm py-3 px-4">${players}</td>`;
            } catch {
              detailRow.innerHTML = '<td colspan="4" class="text-error text-sm">Failed to load details</td>';
            }
          });
        });
      }

      async function loadPage(offset) {
        const btn = document.getElementById('search-btn');
        btn.disabled = true;
        document.getElementById('results').innerHTML = '<span class="loading loading-spinner loading-sm"></span>';
        try {
          const data = await fetchRuns(offset);
          renderResults(data, offset);
        } catch (err) {
          document.getElementById('results').innerHTML = `<p class="text-error text-sm">Error: ${err.message}</p>`;
        } finally {
          btn.disabled = false;
        }
      }

      document.getElementById('query-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        loadPage(0);
      });

      document.getElementById('clear-btn').addEventListener('click', () => {
        Array.from(document.getElementById('cards-select').options).forEach(o => { o.selected = false; });
        document.getElementById('cards-search').value = '';
        Array.from(document.getElementById('cards-select').options).forEach(o => { o.hidden = false; });
        document.getElementById('mode-select').value = 'single';
        document.getElementById('ascension-select').value = '';
        loadPage(0);
      });

    </script>
  </body>
</html>
